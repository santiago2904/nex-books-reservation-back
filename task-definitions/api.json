{
  "family": "nex-books-back",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::150506369483:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::150506369483:role/nex-books-task-role",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "containerDefinitions": [
    {
      "name": "api",
      "image": "150506369483.dkr.ecr.us-east-1.amazonaws.com/nex-books-back:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 4000, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV",        "value": "production" },
        { "name": "PORT",            "value": "4000" },
        { "name": "JWT_EXPIRES_IN",  "value": "1h" },
        { "name": "CORS_ORIGIN",     "value": "https://nex-books-reservation-front.vercel.app" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:150506369483:secret:nex/prod/db-9noSS8:DATABASE_URL::" },
        { "name": "JWT_SECRET",   "valueFrom": "arn:aws:secretsmanager:us-east-1:150506369483:secret:nex/prod/jwt-LU1snk" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:4000/health || exit 1"],
        "interval": 30, "timeout": 5, "retries": 3, "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/nex-books-back",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "api",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
